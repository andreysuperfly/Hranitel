<Window x:Class="Hranitel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hranitel.Controls"
        xmlns:conv="clr-namespace:Hranitel.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Хранитель" Width="440" Height="670"
        MinWidth="440" MinHeight="670" MaxHeight="900"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Background="#1A1B22"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <!-- Pantone Spring 2024 Pastels — Pastel Lilac, Desert Flower, Marlin, Mint -->
        <Color x:Key="BgPrimary">#1A1B22</Color>
        <Color x:Key="BgCard">#24262E</Color>
        <Color x:Key="BgElevated">#2E3039</Color>
        <Color x:Key="BgHover">#3A3D48</Color>
        <Color x:Key="TextPrimary">#E8E6F0</Color>
        <Color x:Key="TextSecondary">#A8A5B8</Color>
        <Color x:Key="TextTertiary">#6B6980</Color>
        <Color x:Key="AccentGreen">#7FB5A8</Color>
        <Color x:Key="AccentPrimary">#BDB0D0</Color>
        <Color x:Key="AccentDanger">#E8A4A0</Color>
        <Color x:Key="AccentSand">#D4C8E0</Color>
        <Color x:Key="BorderSubtle">#3D3E48</Color>

        <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiary}"/>
        <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
        <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}"/>
        <SolidColorBrush x:Key="AccentDangerBrush" Color="{StaticResource AccentDanger}"/>
        <SolidColorBrush x:Key="AccentSandBrush" Color="{StaticResource AccentSand}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderSubtle}"/>
        <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolean"/>
        <conv:SizeToRectConverter x:Key="SizeToRect"/>

        <!-- Скроллбар в стиле приложения -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#24262E"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="#3D3E48" CornerRadius="4" Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Toggle в стиле Fluent — прямоугольный трек, без толстой тени -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="track" Width="44" Height="24" CornerRadius="6"
                                Background="#3D3E48" BorderBrush="#4A4B56" BorderThickness="1" Cursor="Hand">
                            <Border x:Name="thumb" Width="18" Height="18" CornerRadius="4" Margin="2"
                                    HorizontalAlignment="Left" Background="#6B6980" Cursor="Hand"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="#7FB5A8"/>
                                <Setter TargetName="track" Property="BorderBrush" Value="#8FC4B8"/>
                                <Setter TargetName="thumb" Property="Margin" Value="22,2,2,2"/>
                                <Setter TargetName="thumb" Property="Background" Value="#E8E6F0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="track" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка основная — Pastel Lilac -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#BDB0D0"/>
            <Setter Property="Foreground" Value="#1A1B22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#BDB0D0" Opacity="0.2" BlurRadius="6" ShadowDepth="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D4C8E0"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка замок — пиксельный стиль, без скруглений -->
        <Style x:Key="LockButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2E3A"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка danger — Desert Flower пастель -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E8A4A0"/>
            <Setter Property="Foreground" Value="#1A1B22"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#E8A4A0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F0B5B2"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка удаления минималистичная -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6B6980"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3A3D48"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,24,24,24" UseLayoutRounding="False" ClipToBounds="False">
        <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="{Binding ListAreaHeight}"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Таймер -->
        <Border Grid.Row="0" Padding="24,22" Background="{StaticResource BgCardBrush}"
                        CornerRadius="14" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="12" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="БЛОКИРОВАТЬ" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" FontWeight="Medium"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Grid Margin="24,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="124"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*" MinWidth="124"/>
                            </Grid.ColumnDefinitions>
                            <local:TimeEdit Grid.Column="0" Time="{Binding BlockStart, Mode=TwoWay}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="—" Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="20" FontWeight="Light"
                                       VerticalAlignment="Center" Margin="16,0"/>
                            <local:TimeEdit Grid.Column="2" Time="{Binding BlockEnd, Mode=TwoWay}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,20,0,20"/>
                        <Grid>
                            <TextBlock Text="Блокировка" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15" FontWeight="Medium" VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding BlockingEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding LockToggleEnabled}"
                                      Style="{StaticResource ToggleSwitch}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      ToolTip="После включения нельзя выключить 10 минут"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Приложения + перетащите сюда — растягивается при увеличении окна -->
                <Border Grid.Row="1" x:Name="DropZone" Background="{StaticResource BgCardBrush}"
                        CornerRadius="14" Margin="0,0,0,12"
                        MinHeight="{Binding ListAreaHeight}"
                        UseLayoutRounding="False"
                        AllowDrop="{Binding CanAddApps}">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="12" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid x:Name="DropZoneInner" AllowDrop="{Binding CanAddApps}">
                        <Grid.Clip>
                            <RectangleGeometry RadiusX="14" RadiusY="14">
                                <RectangleGeometry.Rect>
                                    <MultiBinding Converter="{StaticResource SizeToRect}"
                                                  FallbackValue="0,0,392,276">
                                        <Binding Path="ActualWidth" ElementName="DropZone"/>
                                        <Binding Path="ActualHeight" ElementName="DropZone"/>
                                    </MultiBinding>
                                </RectangleGeometry.Rect>
                            </RectangleGeometry>
                        </Grid.Clip>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="AppList" Grid.Row="0" ItemsSource="{Binding BlockedApps}"
                                 Background="Transparent" BorderThickness="0"
                                 AllowDrop="{Binding CanAddApps}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="12,14,12,16">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="10" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <CheckBox Grid.Column="1" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      VerticalAlignment="Center" Margin="0,0,16,0"/>
                                            <Button Grid.Column="2" Content="×" Style="{StaticResource GhostButton}"
                                                    Command="{Binding RemoveCommand}"
                                                    FontSize="22" FontWeight="Light"
                                                    ToolTip="Удалить (10 мин после добавления — нельзя)"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <!-- По центру — когда список пуст -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding BlockedAppsCount, Converter={StaticResource CountToVisibility}}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Перетащи приложение или" Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button Content="выбери" Command="{Binding SelectCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding CanAddApps}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. Замок + created by -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Button Command="{Binding ToggleLockCommand}"
                                Style="{StaticResource LockButton}"
                                HorizontalAlignment="Center"
                                ToolTip="Заблокировать настройки на 2 дня">
                            <Button.Content>
                                <ContentControl Content="{Binding Locked}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type sys:Boolean}">
                                            <Viewbox Width="36" Height="44" Stretch="Uniform">
                                                <Grid Width="36" Height="44">
                                                    <!-- Разомкнут (unlocked) -->
                                                    <Canvas x:Name="Unlocked" Visibility="Collapsed" Width="36" Height="44">
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="0" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="30" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="12"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="12"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="30"/>
                                                    </Canvas>
                                                    <!-- Соединён (locked) -->
                                                    <Canvas x:Name="Locked" Visibility="Collapsed" Width="36" Height="44">
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="0" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="30" Canvas.Top="0"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="6"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="12"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="12"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="18"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="24"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="6" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="12" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="18" Canvas.Top="30"/>
                                                        <Rectangle Fill="#8B9FD4" Width="6" Height="6" Canvas.Left="24" Canvas.Top="30"/>
                                                    </Canvas>
                                                </Grid>
                                            </Viewbox>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="True">
                                                    <Setter TargetName="Locked" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="False">
                                                    <Setter TargetName="Unlocked" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </Button.Content>
                        </Button>
                        <TextBlock Text="{Binding LockedUntilText}" Foreground="{StaticResource AccentDangerBrush}"
                                   FontSize="13" FontWeight="Medium"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <!-- Кнопка Логи отключена
                            <Button Content="Логи" Command="{Binding CopyLogsCommand}"
                                    Background="Transparent" Foreground="{StaticResource TextTertiaryBrush}"
                                    BorderThickness="0" Padding="8,4" FontSize="11" Cursor="Hand"
                                    ToolTip="Скопировать логи в буфер"/>
                            -->
                            <TextBlock Text="created by andrey superfly"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="10" Opacity="0.7"
                                       VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
    </Grid>
</Window>
